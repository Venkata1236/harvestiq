# Groq API (get from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/harvestiq

# App
ENV=development
LOG_LEVEL=DEBUG

# Model paths
MODEL_PATH=saved_models/harvestiq_resnet50.pt
CLASS_NAMES_PATH=saved_models/class_names.json
CONFIDENCE_THRESHOLD=0.65

# ChromaDB
CHROMA_DB_PATH=chroma_db/
